{
  "name": "vue-i18next-example",
  "targets": {
    "i18n": {
      "executor": "i18n-keygen:keys",
      "options": { "configFile": "apps/vue-i18next/i18n.config.json" },
      "inputs": ["{projectRoot}/i18n.config.json", "{projectRoot}/public/locales/**/*.json"],
      "outputs": ["{projectRoot}/src/i18n/i18n-keys.generated.ts"],
      "cache": true
    },
    "i18n-watch": {
      "executor": "i18n-keygen:keys",
      "continuous": true,
      "options": { "configFile": "apps/vue-i18next/i18n.config.json" }
    },
    "serve": {
      "executor": "nx:run-commands",
      "continuous": true,
      "dependsOn": ["i18n-watch"],
      "options": {
        "command": "npx vite",
        "cwd": "apps/vue-i18next"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["i18n"],
      "options": {
        "command": "npx vite build",
        "cwd": "apps/vue-i18next"
      }
    }
  }
}
